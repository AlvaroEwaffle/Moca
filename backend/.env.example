# Moca Backend & MCP Server Configuration
# Copy this file to .env and fill in your values

# MongoDB
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/moca?retryWrites=true

# JWT Authentication
JWT_SECRET=your-jwt-secret-key-min-32-characters

# Encryption
ENCRYPTION_KEY=32-character-encryption-key-here

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Instagram
INSTAGRAM_CLIENT_ID=your-instagram-client-id
INSTAGRAM_CLIENT_SECRET=your-instagram-client-secret
INSTAGRAM_REDIRECT_URI=https://your-domain.com/instagram-oauth-callback
INSTAGRAM_APP_SECRET=your-instagram-app-secret
INSTAGRAM_VERIFY_TOKEN=your-webhook-verify-token
INSTAGRAM_ACCESS_TOKEN=your-long-lived-access-token

# Server
PORT=3002
MCP_PORT=4002
NODE_ENV=production

# Optional: Slack notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Optional: Firebase (for external integrations)
FIREBASE_API_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=

# Analytics
LEAD_SCORE_THRESHOLD=4
ANALYTICS_WINDOW_DAYS=7

# Pagination
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=200
